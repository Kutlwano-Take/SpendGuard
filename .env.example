# ─────────────────────────────────────────────
# LOCAL DEVELOPMENT VARIABLES (SAM CLI)
# ─────────────────────────────────────────────

# API base URL — defaults to http://localhost:3001 for local SAM dev.
# Must be set to your API Gateway URL for production.
VITE_API_BASE_URL=http://localhost:3001

# Cognito configuration (replace with your real values locally or in Amplify console)
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=

# ─────────────────────────────────────────────
# PRODUCTION-REQUIRED VARIABLES
# ─────────────────────────────────────────────

# Backend AWS Region
AWS_REGION=af-south-1

# DynamoDB table name
TABLE_NAME=SpendGuardTable

# S3 bucket for receipts
RECEIPTS_BUCKET=spendguard-receipts-local

# SES configuration
SES_FROM_EMAIL=noreply@spendguard.local

# Cognito configuration
COGNITO_USER_POOL_ID=af-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# LOCAL BACKEND OVERRIDES (SAM CLI only)
# ─────────────────────────────────────────────

# Local DynamoDB endpoint
DYNAMODB_ENDPOINT=http://localhost:8000

# Development flags
AWS_SAM_LOCAL=true
NODE_ENV=development
